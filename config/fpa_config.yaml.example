# FPA 专用配置
# 复制到 ~/.ai-gen-reimbursement-docs/fpa_config.yaml 后生效
#
# default-profile 决定默认 FPA 方案；CLI/Web/API 显式传入 fpa_profile 时优先使用显式值。

default-profile: strict_fpa
judgement_rules_source: config

# FPA 调整值计算配置。
# legacy_workload: 简化历史口径，调整值来自 type_weights。
# standard_fpa: 标准 FPA 口径，AI 输出 DET/RET/FTR 证据，代码按矩阵复算复杂度和 FP。
adjustment_value_method_default: standard_fpa

adjustment_value_methods:
  legacy_workload:
    type_weights:
      EI: 2
      default: 1
  standard_fpa:
    complexity_source: ai
    fallback_complexity: low
    weights:
      ILF:
        low: 7
        medium: 10
        high: 15
      EIF:
        low: 5
        medium: 7
        high: 10
      EI:
        low: 3
        medium: 4
        high: 6
      EO:
        low: 4
        medium: 5
        high: 7
      EQ:
        low: 3
        medium: 4
        high: 6
    data_function_complexity_matrix:
      - {ret_min: 1, ret_max: 1, det_min: 1, det_max: 19, complexity: low}
      - {ret_min: 1, ret_max: 1, det_min: 20, det_max: 50, complexity: low}
      - {ret_min: 1, ret_max: 1, det_min: 51, complexity: medium}
      - {ret_min: 2, ret_max: 5, det_min: 1, det_max: 19, complexity: low}
      - {ret_min: 2, ret_max: 5, det_min: 20, det_max: 50, complexity: medium}
      - {ret_min: 2, ret_max: 5, det_min: 51, complexity: high}
      - {ret_min: 6, det_min: 1, det_max: 19, complexity: medium}
      - {ret_min: 6, det_min: 20, det_max: 50, complexity: high}
      - {ret_min: 6, det_min: 51, complexity: high}
    transaction_complexity_matrices:
      EI:
        - {ftr_min: 0, ftr_max: 1, det_min: 1, det_max: 4, complexity: low}
        - {ftr_min: 0, ftr_max: 1, det_min: 5, det_max: 15, complexity: low}
        - {ftr_min: 0, ftr_max: 1, det_min: 16, complexity: medium}
        - {ftr_min: 2, ftr_max: 2, det_min: 1, det_max: 4, complexity: low}
        - {ftr_min: 2, ftr_max: 2, det_min: 5, det_max: 15, complexity: medium}
        - {ftr_min: 2, ftr_max: 2, det_min: 16, complexity: high}
        - {ftr_min: 3, det_min: 1, det_max: 4, complexity: medium}
        - {ftr_min: 3, det_min: 5, det_max: 15, complexity: high}
        - {ftr_min: 3, det_min: 16, complexity: high}
      EO:
        - {ftr_min: 0, ftr_max: 1, det_min: 1, det_max: 5, complexity: low}
        - {ftr_min: 0, ftr_max: 1, det_min: 6, det_max: 19, complexity: low}
        - {ftr_min: 0, ftr_max: 1, det_min: 20, complexity: medium}
        - {ftr_min: 2, ftr_max: 3, det_min: 1, det_max: 5, complexity: low}
        - {ftr_min: 2, ftr_max: 3, det_min: 6, det_max: 19, complexity: medium}
        - {ftr_min: 2, ftr_max: 3, det_min: 20, complexity: high}
        - {ftr_min: 4, det_min: 1, det_max: 5, complexity: medium}
        - {ftr_min: 4, det_min: 6, det_max: 19, complexity: high}
        - {ftr_min: 4, det_min: 20, complexity: high}
      EQ:
        - {ftr_min: 0, ftr_max: 1, det_min: 1, det_max: 5, complexity: low}
        - {ftr_min: 0, ftr_max: 1, det_min: 6, det_max: 19, complexity: low}
        - {ftr_min: 0, ftr_max: 1, det_min: 20, complexity: medium}
        - {ftr_min: 2, ftr_max: 3, det_min: 1, det_max: 5, complexity: low}
        - {ftr_min: 2, ftr_max: 3, det_min: 6, det_max: 19, complexity: medium}
        - {ftr_min: 2, ftr_max: 3, det_min: 20, complexity: high}
        - {ftr_min: 4, det_min: 1, det_max: 5, complexity: medium}
        - {ftr_min: 4, det_min: 6, det_max: 19, complexity: high}
        - {ftr_min: 4, det_min: 20, complexity: high}

# strategy 支持 rules_first / ai_first / rules_only / ai_only。
# ai_only 不使用规则生成或补齐行，AI 失败时直接报错；但 rule_set 仍用于
# 配置校验、AI 结果后处理、非法类型兜底、冲突 warning、审核追踪和缓存 key。
profiles:
  strict_fpa:
    kind: strict_fpa
    strategy: ai_first
    rule_set: strict_fpa_rs
    core_rules: strict_fpa_cr
    system_prompt: strict_fpa_sp
    user_prompt: strict_fpa_up

  unified_ui:
    kind: unified_ui
    strategy: rules_first
    rule_set: unified_ui_rs
    core_rules: unified_ui_cr
    system_prompt: unified_ui_sp
    user_prompt: unified_ui_up

  multi_uis:
    kind: unified_ui
    strategy: rules_first
    rule_set: multi_uis_rs
    core_rules: multi_uis_cr
    system_prompt: multi_uis_sp
    user_prompt: multi_uis_up

  ui_api_mapping:
    kind: ui_api_mapping
    strategy: rules_first
    rule_set: ui_api_mapping_rs
    core_rules: ui_api_mapping_cr
    system_prompt: ui_api_mapping_sp
    user_prompt: ui_api_mapping_up

core_rules:
  strict_fpa_cr: |-
    严格 FPA 核心口径：
    1. 按标准 FPA 的数据功能和事务功能拆分，不按开发工作项、页面、按钮、弹窗、接口或数据库表字段拆分。
    2. 不生成“界面开发”“接口开发”“逻辑处理开发”等开发工作项行。
    3. 本系统维护的逻辑数据组生成 ILF；外部系统维护、本系统引用的数据组生成 EIF。
    4. 新增、修改、删除、保存、提交、审批、启用、停用、导入等进入或改变系统边界内数据的事务功能为 EI。
    5. 查询、查看、详情、检索等无派生输出的读取事务功能为 EQ。
    6. 导出、报表、下载文件、生成文件等有派生或格式化输出的事务功能为 EO。
    7. 普通外部服务调用不等于 EIF；只有明确引用外部维护的数据组时才生成 EIF。
    8. 输入中的功能过程类型只能作为参考；当功能过程类型与功能过程名称或描述冲突时，以名称和描述为准。
    9. 功能过程不是功能点计数单位；同一业务对象、同一数据组、同一管理或查询场景下的多个过程，应按逻辑事务合并。
    10. 同一 ILF 的新增、修改、删除、启用、停用、保存等维护动作，属于同一业务对象和同一管理场景时，合并为一个维护类 EI。
    11. 默认列表查询、条件搜索、按名称查询、筛选查询读取同一数据组并展示同类结果时，合并为一个查询类 EQ。
    12. 计算依据归类只能从给定判定原则列表中选择，不要自造分类。

  unified_ui_cr: |-
    统一界面 FPA 核心口径：
    1. 拆分先按业务能力粒度，不按按钮、弹窗、数据库表、字段或技术实现拆分。
    2. 同一三级模块中的列表、查询条件、按钮、新增/编辑弹窗、状态切换等界面能力默认合并为 1 条界面开发行。
    3. 非界面类后端逻辑按功能动作拆分，一行表示一个业务动作或数据处理能力。
    4. 新增表、保存表、字段维护等不要单独生成 FPA 行，应归属到对应功能动作中。
    5. 类型可使用 EI、ILF、EQ、EO、EIF：界面交互通常为 EI；内部数据维护通常为 ILF；查询读取通常为 EQ；导出/报表输出通常为 EO；EIF 仅用于引用其他应用维护的数据组。
    6. 计算依据归类只能从给定判定原则列表中选择，不要自造分类。

  multi_uis_cr: |-
    多界面 FPA 核心口径：
    1. 同一三级模块允许按独立页面、独立业务对象、独立业务流程或独立用户端拆分多条界面开发行。
    2. 每条多界面拆分行必须给出可审阅的拆分理由，拆分理由进入 check/review 元数据。
    3. 界面开发行统一为 EI。
    4. 非界面业务动作行沿用统一界面口径的类型规则。

  ui_api_mapping_cr: |-
    界面接口映射 FPA 核心口径：
    1. 每个功能过程默认生成 1 条界面开发行和 1 条接口开发行。
    2. 功能过程界面开发行固定为 EI，功能过程接口开发行固定为 ILF。
    3. 输入中明确出现的接口、服务、调用、请求、对接、同步、外部系统、第三方或 API 单独生成明确接口/后端调用行，固定为 ILF。
    4. 普通动作词“保存、提交、删除、审批、新增、修改”不触发额外明确接口/后端调用行。
    5. 明确接口/后端调用行保留原文接口/服务名称主体，并使用完整模块路径前缀。

system_prompt_sets:
  strict_fpa_sp: |-
    你是一个严谨的 FPA 功能点评估助手。你的任务是根据用户提示词中给定的 strict_fpa 口径、计算依据归类判定原则和三级模块业务输入，规划标准 FPA 功能点评估行。

    ## 通用约束
    1. 必须遵守用户提示词中的严格 FPA 口径，不按开发工作项拆分。
    2. 类型必须为 EI / EO / EQ / ILF / EIF 之一。
    3. 用户提供了带序号的「计算依据归类判定原则列表」，请返回最匹配的 classification_basis_index。
    4. 计算依据说明必须基于输入业务内容，按用户提示词中的结构化证据说明规则生成；不要编造不存在的页面、表、服务、接口或流程。
    5. 不允许输出除 JSON 外的任何内容。

  unified_ui_sp: |-
    你是一个严谨的 FPA 功能点评估助手。你的任务是根据用户提示词中给定的 unified_ui 口径、计算依据归类判定原则和三级模块业务输入，规划 FPA 功能点评估行。

    ## 通用约束
    1. 必须遵守用户提示词中的统一界面口径。
    2. 不要机械地为每个功能过程固定生成界面开发或接口开发行。
    3. 类型必须为 EI / EO / EQ / ILF / EIF 之一。
    4. 用户提供了带序号的「计算依据归类判定原则列表」，请返回最匹配的 classification_basis_index。
    5. 计算依据说明必须基于输入业务内容，按用户提示词中的结构化证据说明规则生成；不要编造不存在的页面、表、服务、接口或流程。
    6. 不允许输出除 JSON 外的任何内容。

  multi_uis_sp: |-
    你是一个严谨的 FPA 功能点评估助手。你的任务是根据 multi_uis 口径规划多界面功能点评估行，并把拆分理由放入 split_reason 供 check/review 元数据记录。

  ui_api_mapping_sp: |-
    你是一个严谨的 FPA 功能点评估助手。你的任务是按 ui_api_mapping 口径规划功能过程到界面开发和接口开发的映射。界面开发固定 EI，接口开发和明确接口/后端调用固定 ILF。

user_prompt_sets:
  # user 模板只支持并且必须包含这三个占位符：
  # ${core_rules}、${judgement_rules}、${payload_json}
  # domain_context 已包含在 ${payload_json} 中，不是独立占位符。
  unified_ui_up: |-
    ${core_rules}

    计算依据归类判定原则列表（只能返回最匹配的序号，序号从1开始）：
    ${judgement_rules}

    请以三级模块为单位规划 FPA 行：
    1. 默认生成 1 条三级模块级界面开发行，覆盖同一页面内的列表、查询条件、按钮、弹窗和状态组件。
    2. 非界面逻辑按功能动作拆分，一行一个动作。
    3. 不要为数据库表、字段、保存表动作单独生成行。
    4. 如果确实需要多条界面开发行，每条都必须给出 split_reason。
    5. name 必须使用模块输入 JSON 中的 client_type / l1 / l2 / l3 作为前缀，格式为「【客户端类型】一级模块-二级模块-三级模块-功能点名称」。
    6. name 不得只返回功能过程名，不得用子系统（模块）替代客户端类型，不得省略客户端类型外侧的「【】」。

    计算依据说明生成规则：
    1. explanation 必须写成结构化证据说明，固定包含「来源场景」「业务数据」「业务规则」「计算说明」；只有输入中明确出现表、服务、接口、文件、外部系统等系统元素时，才输出「系统元素」。
    2. 来源场景必须使用完整路径；EI/EQ/EO 事务功能使用「【客户端类型】一级模块-二级模块-三级模块-功能点名称」，ILF/EIF 数据功能使用「【客户端类型】一级模块-二级模块-三级模块-数据组名称」，并保留用户动作、系统动作或数据组识别来源。
    3. 业务数据描述业务对象、逻辑数据组、字段或状态；可以合理归纳业务对象，但不得把数据库表直接等同为 ILF。
    4. 系统元素只列出输入中明确出现的表、服务、接口、文件或外部系统；未明确出现时，正式 explanation 中省略「系统元素」，不要写“未识别到”。
    5. 计算说明必须说明为什么纳入 FPA 功能点计量，并明确当前类型 EI / EO / EQ / ILF / EIF。
    6. 计算依据归类中的短依据可以是模板判定原则原文，但 explanation 不要把“按后台数据库变更的表个数计量”“按数据库表个数计量”等归类依据改写成详细计量解释。
    7. 每项 1 句，总体建议 80-180 字；不要为凑字数补充输入中没有的权限、审批、状态流、表名、服务名或接口名。

    模块输入 JSON：
    ${payload_json}

    请直接输出 JSON，不要输出其他内容。格式：
    {"rows":[{"name":"<功能点名称>","type":"EI/ILF/EQ/EO/EIF","type_reason":"<类型理由>","classification_basis_index":1,"explanation":"来源场景：...\n业务数据：...\n业务规则：...\n系统元素：...\n计算说明：...","source_processes":["<功能过程名称>"],"split_reason":"<多界面拆分理由，可空>","complexity":"low/medium/high","det_count":8,"ret_count":null,"ftr_count":2,"complexity_reason":"说明 DET、RET/FTR 的识别依据和配置矩阵命中原因。"}]}

  strict_fpa_up: |-
    ${core_rules}

    计算依据归类判定原则列表（只能返回最匹配的序号，序号从1开始）：
    ${judgement_rules}

    请以严格 FPA 口径规划本三级模块的 FPA 行：
    1. 先识别数据功能：本系统维护的数据组为 ILF，外部维护且本系统引用的数据组为 EIF。
    2. 再识别事务功能：新增/修改/删除/保存/提交/审批/导入为 EI，查询/查看/详情为 EQ，导出/报表/下载文件为 EO。
    3. 禁止输出界面开发、接口开发、逻辑处理开发、按钮、弹窗、数据库表或字段行。
    4. 普通外部服务调用不要直接输出 EIF，除非明确引用外部维护的数据组。
    5. 功能过程类型只能作为参考，不作为最终判定依据；当功能过程类型与功能过程名称或描述冲突时，以功能过程名称和描述为准。
    6. processes 只是候选业务步骤，不是功能点计数单位；不得因为有 N 个 processes 就机械输出 N 个事务功能点。
    7. 对同一个 ILF 的新增、修改、删除、启用、停用、保存等维护动作，如果属于同一业务对象、同一管理界面或同一组操作入口，必须合并为一个维护类 EI，功能点名称建议使用「xxx维护」。
    8. 默认列表查询、条件搜索、按名称查询、筛选查询，如果读取同一数据组、展示同一类结果、属于同一列表或查询界面，必须合并为一个查询类 EQ，功能点名称建议使用「xxx查询」。
    9. 手机号校验、账号校验、权限校验、认证校验、短信发送、支付调用、OCR 调用、消息推送等普通外部服务调用，不生成 EIF；只有输入明确说明外部系统维护的数据组被本系统读取或引用时，才生成 EIF。
    10. 合并行必须在 source_processes 中列出全部来源功能过程，并在 split_reason 中说明合并原因。
    11. ILF/EIF 数据功能名称建议使用「xxx数据组」后缀，例如「垂直行业数据组」；EI 维护类事务建议使用「xxx维护」，EQ 查询类事务建议使用「xxx查询」，EO 输出类事务建议使用「xxx输出/xxx导出/xxx报表」。
    12. name 必须使用模块输入 JSON 中的 client_type / l1 / l2 / l3 作为前缀，格式为「【客户端类型】一级模块-二级模块-三级模块-功能点名称」。
    13. name 不得只返回功能过程名，不得用子系统（模块）替代客户端类型，不得省略客户端类型外侧的「【】」。

    计算依据说明生成规则：
    1. explanation 必须写成结构化证据说明，固定包含「来源场景」「业务数据」「业务规则」「计算说明」；只有输入中明确出现表、服务、接口、文件、外部系统等系统元素时，才输出「系统元素」。
    2. 来源场景必须使用完整路径；EI/EQ/EO 事务功能使用「【客户端类型】一级模块-二级模块-三级模块-功能点名称」，ILF/EIF 数据功能使用「【客户端类型】一级模块-二级模块-三级模块-数据组名称」，并保留用户动作、系统动作或数据组识别来源。
    3. 业务数据描述业务对象、逻辑数据组、字段或状态；可以合理归纳业务对象，但不得把数据库表直接等同为 ILF。
    4. 系统元素只列出输入中明确出现的表、服务、接口、文件或外部系统；未明确出现时，正式 explanation 中省略「系统元素」，不要写“未识别到”。
    5. 计算说明必须说明为什么纳入 FPA 功能点计量，并明确当前类型 EI / EO / EQ / ILF / EIF。
    6. 计算依据归类中的短依据可以是模板判定原则原文，但 explanation 不要把“按后台数据库变更的表个数计量”“按数据库表个数计量”等归类依据改写成详细计量解释。
    7. 每项 1 句，总体建议 80-180 字；不要为凑字数补充输入中没有的权限、审批、状态流、表名、服务名或接口名。

    模块输入 JSON：
    ${payload_json}

    请直接输出 JSON，不要输出其他内容。格式：
    {"rows":[{"name":"<功能点名称>","type":"EI/ILF/EQ/EO/EIF","type_reason":"<类型理由>","classification_basis_index":1,"explanation":"来源场景：...\n业务数据：...\n业务规则：...\n系统元素：...\n计算说明：...","source_processes":["<功能过程名称>"],"split_reason":"<合并或拆分原因，可空>","complexity":"low/medium/high","det_count":8,"ret_count":null,"ftr_count":2,"complexity_reason":"说明 DET、RET/FTR 的识别依据和配置矩阵命中原因。"}]}

  multi_uis_up: |-
    ${core_rules}

    计算依据归类判定原则列表（只能返回最匹配的序号，序号从1开始）：
    ${judgement_rules}

    请以多界面口径规划 FPA 行：
    1. 可按独立页面、独立业务对象、独立业务流程或独立用户端拆分多条界面开发行。
    2. 每条界面开发行必须在 split_reason 中写明拆分理由，供 check/review 元数据记录。
    3. 界面开发行固定 EI；非界面业务动作沿用统一界面类型规则。
    4. name 必须使用完整模块路径前缀，格式为「【客户端类型】一级模块-二级模块-三级模块-功能点名称」。

    模块输入 JSON：
    ${payload_json}

    请直接输出 JSON，不要输出其他内容。格式：
    {"rows":[{"name":"<功能点名称>","type":"EI/ILF/EQ/EO/EIF","type_reason":"<类型理由>","classification_basis_index":1,"explanation":"来源场景：...\n业务数据：...\n业务规则：...\n计算说明：...","source_processes":["<功能过程名称>"],"split_reason":"<独立页面/独立业务对象/独立业务流程/独立用户端>","complexity":"low/medium/high","det_count":8,"ret_count":null,"ftr_count":2,"complexity_reason":"说明 DET、RET/FTR 的识别依据和配置矩阵命中原因。"}]}

  ui_api_mapping_up: |-
    ${core_rules}

    计算依据归类判定原则列表（只能返回最匹配的序号，序号从1开始）：
    ${judgement_rules}

    请以界面接口映射口径规划 FPA 行：
    1. 每个功能过程默认生成 1 条「功能过程-界面开发」行，类型固定 EI。
    2. 每个功能过程默认生成 1 条「功能过程-接口开发」行，类型固定 ILF。
    3. 输入中明确出现的接口、服务、调用、请求、对接、同步、外部系统、第三方或 API 单独生成明确接口/后端调用行，类型固定 ILF。
    4. 明确接口/后端调用行不再配套生成界面开发行；普通保存、提交、删除、审批、新增、修改不触发额外明确接口/后端调用行。
    5. name 必须使用完整模块路径前缀，格式为「【客户端类型】一级模块-二级模块-三级模块-功能点名称」。

    模块输入 JSON：
    ${payload_json}

    请直接输出 JSON，不要输出其他内容。格式：
    {"rows":[{"name":"<功能点名称>","type":"EI/ILF","type_reason":"<类型理由>","classification_basis_index":1,"explanation":"来源场景：...\n业务数据：...\n业务规则：...\n计算说明：...","source_processes":["<功能过程名称>"],"split_reason":"","complexity":"low/medium/high","det_count":8,"ret_count":null,"ftr_count":2,"complexity_reason":"说明 DET、RET/FTR 的识别依据和配置矩阵命中原因。"}]}

rule_sets:
  # type_mapping_rules：直接把关键词映射到 EI/EQ/EO/ILF/EIF，适合项目级特例、业务对象或数据组边界。
  # keyword_rules：事务动作关键词规则，主要用于 EI/EQ/EO，例如新增/查询/导出。
  # strict_fpa 类型推断中，type_mapping_rules 先于普通事务关键词判断，可用于覆盖明确特例。
  # unified_ui 的默认规则集。
  # 适合继续使用报账材料中的模板友好表达，例如界面开发、逻辑处理开发、查询处理开发。
  unified_ui_rs:
    row_planning_rules:
      ui_row:
        enabled: true
        scope: l3
        merge: single_row
        name_suffix: "界面开发"
        type: EI
        reason: "三级模块兜底合并界面能力。"
        empty_process_text: "完成三级模块页面交互能力"
        explanation_template: "{name}，具体为以下：\n{items}"
      process_rows:
        enabled: true
        one_row_per_process: true
        default_name_suffix: "逻辑处理开发"
        type_suffixes:
          EQ: "查询处理开发"
          EO: "导出处理开发"
          EI: "导入处理开发"
        explanation_template: "{name}，具体为以下：\n1、{description}"
    type_mapping_rules:
      merge: append
      items:
        - type: EI
          keywords: ["界面开发", "页面"]
          reason: "关键词命中界面/页面能力，按 EI 兜底。"
        - type: EIF
          keywords: ["外部应用维护", "外部系统维护", "引用外部数据组", "统一用户中心", "外部主数据"]
          reason: "描述明确引用外部应用维护的数据组，按 EIF 兜底。"
        - type: ILF
          keywords: ["添加", "新增", "编辑", "修改", "删除", "维护", "保存", "启用", "停用", "更新"]
          reason: "关键词命中内部数据维护能力，按 ILF 兜底。"
        - type: ILF
          keywords: ["外部接口", "外部数据"]
          reason: "仅出现外部接口或外部数据不足以判定 EIF，按 ILF 兜底。"
    keyword_rules:
      merge: append
      items:
        - type: EO
          keywords: ["导出", "报表输出", "生成文件", "下载", "下载模板", "下载文件"]
          reason: "关键词命中导出/输出能力，按 EO 兜底。"
        - type: EQ
          keywords: ["查询", "查看", "详情", "列表检索", "检索"]
          reason: "关键词命中查询/查看能力，按 EQ 兜底。"
        - type: EI
          keywords: ["导入"]
          reason: "关键词命中导入能力，通常表示外部数据进入系统，按 EI 兜底。"
    coverage_rules:
      require_process_coverage: true
      require_data_function: true

  multi_uis_rs:
    row_planning_rules:
      ui_row:
        enabled: false
        scope: l3
        merge: single_row
        name_suffix: "界面开发"
        type: EI
        reason: "多界面口径由 AI 或后续规则按拆分理由生成多条界面行。"
        empty_process_text: "完成三级模块多界面交互能力"
        explanation_template: "{name}，具体为以下：\n{items}"
      process_rows:
        enabled: true
        one_row_per_process: true
        default_name_suffix: "逻辑处理开发"
        type_suffixes:
          EQ: "查询处理开发"
          EO: "导出处理开发"
          EI: "导入处理开发"
        explanation_template: "{name}，具体为以下：\n1、{description}"
    type_mapping_rules:
      merge: append
      items:
        - type: EI
          keywords: ["界面开发", "页面"]
          reason: "多界面开发行按 EI。"
        - type: EIF
          keywords: ["外部应用维护", "外部系统维护", "引用外部数据组", "统一用户中心", "外部主数据"]
          reason: "描述明确引用外部应用维护的数据组，按 EIF 兜底。"
        - type: ILF
          keywords: ["添加", "新增", "编辑", "修改", "删除", "维护", "保存", "启用", "停用", "更新"]
          reason: "关键词命中内部数据维护能力，按 ILF 兜底。"
    keyword_rules:
      merge: append
      items:
        - type: EO
          keywords: ["导出", "报表输出", "生成文件", "下载", "下载模板", "下载文件"]
          reason: "关键词命中导出/输出能力，按 EO 兜底。"
        - type: EQ
          keywords: ["查询", "查看", "详情", "列表检索", "检索"]
          reason: "关键词命中查询/查看能力，按 EQ 兜底。"
        - type: EI
          keywords: ["导入"]
          reason: "关键词命中导入能力，通常表示外部数据进入系统，按 EI 兜底。"
    coverage_rules:
      require_process_coverage: true
      require_data_function: true

  ui_api_mapping_rs:
    coverage_rules:
      require_process_coverage: true
      require_data_function: false

  # strict_fpa 的默认规则集。
  # 适合按标准 FPA 的 EI / EQ / EO / ILF / EIF 口径生成结果。
  strict_fpa_rs:
    keyword_rules:
      merge: append
      items:
        - type: EO
          keywords: ["导出", "报表", "下载", "生成文件"]
          reason: "事务功能产生派生或格式化输出，按 EO。"
        - type: EQ
          keywords: ["查询", "查看", "详情", "检索", "列表"]
          reason: "事务功能读取数据且无派生输出，按 EQ。"
        - type: EI
          keywords: ["新增", "添加", "修改", "编辑", "删除", "保存", "提交", "审批", "启用", "停用", "导入", "同步", "发起", "写入", "选择", "引用", "关联"]
          reason: "事务功能进入或改变系统边界内数据，按 EI。"
    external_data_rules:
      merge: append
      items:
        - source_aliases: ["统一用户中心", "用户中心"]
          data_name: "统一用户中心账号"
          data_nouns: ["账号", "账户", "人员", "组织", "机构", "信息"]
        - source_aliases: ["CRM", "客户关系管理系统"]
          data_name: "CRM客户档案"
          data_nouns: ["客户", "档案", "信息", "记录", "主数据"]
        - source_aliases: ["客户中心", "客户主数据平台"]
          data_name: "客户中心客户档案"
          data_nouns: ["客户", "档案", "信息", "记录", "主数据"]
        - source_aliases: ["财务核算系统"]
          data_name: "财务核算单据"
          data_nouns: ["单据", "报账", "凭证", "记录", "信息"]
        - source_aliases: ["财务系统"]
          data_name: "财务系统单据"
          data_nouns: ["单据", "报账", "凭证", "记录", "信息"]
        - source_aliases: ["ERP", "ERP系统"]
          data_name: "ERP业务单据"
          data_nouns: ["单据", "订单", "物料", "供应商", "记录", "信息"]
        - source_aliases: ["OA", "OA系统"]
          data_name: "OA流程单据"
          data_nouns: ["单据", "流程", "审批", "记录", "信息"]
        - source_aliases: ["主数据平台", "外部主数据"]
          data_name: "组织主数据"
          data_nouns: ["组织", "机构"]
        - source_aliases: ["主数据平台", "外部主数据"]
          data_name: "外部主数据"
          data_nouns: ["主数据", "基础数据", "数据组", "信息"]
    coverage_rules:
      require_process_coverage: true
      require_data_function: true

  # 示例：更保守的 strict_fpa 扩展规则集。
  # 该规则集不是 strict_fpa 的默认口径，主要演示如何通过 extends 追加项目级规则。
  strict_fpa_conservative:
    extends: strict_fpa_rs
    keyword_rules:
      merge: append
      items:
        - type: EO
          keywords: ["打印清单", "打印报表"]
          reason: "打印清单或报表属于格式化输出，按 EO。"
    type_mapping_rules:
      merge: append
      items:
        - type: ILF
          keywords: ["本地报表快照"]
          reason: "本系统持久化报表快照，按 ILF。"
    ai_type_conflict_rules:
      merge: append
      items:
        - expected_type: ILF
          ai_type: EO
          keywords: ["本地报表快照"]
          conflict: false
          reason: "示例：已确认项目口径允许 AI 按格式化输出复核时，不提示类型冲突。"
    internal_data_rules:
      merge: append
      items:
        - keywords: ["认证授权关系", "角色授权关系"]
          data_name: "认证授权关系"
          reason: "本系统维护认证授权关系，按 ILF。"
    external_data_rules:
      merge: append
      items:
        - source_aliases: ["统一认证平台", "统一认证"]
          data_name: "统一认证账号"
          data_nouns: ["账号", "账户", "人员"]
    # 覆盖补齐策略。不配置时默认均为 true。
    # require_process_coverage=true 表示 AI 未覆盖功能过程时追加 rules_fallback 行。
    # require_data_function=true 表示 strict_fpa/ai_first 下 AI 缺少 ILF/EIF 数据功能行时按规则补齐。
    coverage_rules:
      require_process_coverage: true
      require_data_function: true

  # 示例：客户 A 的规则集。
  client_a_rules:
    extends: strict_fpa_rs
    external_data_rules:
      merge: append
      items:
        - source_aliases: ["供应商平台"]
          data_name: "供应商平台供应商档案"
          data_nouns: ["供应商", "档案", "信息"]
