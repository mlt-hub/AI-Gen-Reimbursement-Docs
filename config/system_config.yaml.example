# AI生成项目报账文档 — 系统配置

# 根据需要设置 开始

# AI生成文档完成后，是否播放提示音（默认false）
# 需要声音提示，可设置为true
# 注：用Web UI的远程服务模式时，此参数失效
notify_sound: false

# 项目功能点拆分表，是否在输出Excel中标记数据异常警告（默认false）
cosmic_warn_marker: false

# 项目功能点拆分表，是否在日志中输出数据异常警告（默认true）
cosmic_warn_log: true

# 项目需求说明书的目录，是否用Word COM自动更新（需安装Microsoft Word，默认true）
# 如没安装Microsoft Word，通常设置为false，因为设置为true，也不会自动更新目录
spec_auto_update_toc: true

# 项目需求说明书的目录，如果没有用Word COM自动更新或用Word COM自动更新失败，
# 文件名前是否添加提醒前缀：“【提醒】请手动更新整个目录”，（默认true）
# 如没安装Microsoft Word，通常设置为true，加提醒
spec_remind_update_toc: true

# Web UI工作模式（auto=IP自动判断, local=强制本机模式, remote=强制远程服务模式，默认auto）
web_work_mode: auto

# Web UI 远程服务模式是否允许注册（默认true），设为 false 禁止新用户注册
allow_register: true

# Web UI端口号，如遇端口冲突（启动报错或页面打不开），换个端口即可，如 9090、3000
web_port: 8080

# Web UI远程服务模式下，临时交付物下载保留天数（默认1天）
# 过期后会清理下载文件，但运行历史记录仍应保留
remote_session_retention_days: 1

# 日志级别（DEBUG/INFO/WARNING/ERROR），默认INFO
log_level: INFO

# AI每次调用的最大输出token数（支持K/M单位，如384K，默认6000）
# 如果AI response数据被截断，增大max_tokens
max_tokens: 6000

# FPA 规划口径。可用：custom_rules（用户自定义规则口径）、strict_fpa（严格FPA口径）
fpa_profile: custom_rules

# FPA 执行策略。留空时跟随 profile 默认：
# custom_rules => rules_first；strict_fpa => ai_first。
# 可用：rules_first（规则优先）、ai_first（AI优先）、rules_only（仅规则）、ai_only（仅AI）。
fpa_strategy: ""

# FPA 规则集名称。留空时跟随 profile 默认：
# custom_rules => custom_rules_default；strict_fpa => strict_fpa_default。
fpa_rule_set: ""

# FPA 审核副本列配置。留空或不配置时使用默认列。
# 支持按 Sheet 名称选择列并调整顺序；未知列名会被忽略。
# fpa_check_columns:
#   FPA结果: ["序号", "新增/修改功能点", "类型", "生成方式", "后处理警告"]
#   Warnings: ["级别", "对象", "Warning", "来源规则ID"]
#   规则命中详情: ["功能点名称", "规则ID", "规则说明", "建议类型", "是否采用", "Warnings"]
fpa_check_columns: {}

# strict_fpa 外部数据组扩展规则。
# 这里只扩展内置规则，不覆盖内置规则；普通外部服务调用不要配置为数据组。
# source_aliases：外部系统/平台名称或别名；data_name：生成的 EIF 数据组名称；data_nouns：识别为数据组所需的业务名词线索。
fpa_external_data_rules:
  - source_aliases: ["统一认证平台", "统一认证"]
    data_name: "统一认证账号"
    data_nouns: ["账号", "账户", "人员"]

# LLM API 单次调用超时时间（秒，默认120）
# 点击"停止"后，系统需等当前API调用结束才能退出
# 此值设得越大，停止后等待越久，不建议超过 300
llm_api_timeout_seconds: 120

# 根据需要设置 结束


# debug设置 开始

# 以下在debug的时候，常用

# AI调用费时费token
# 限制AI批处理数量，超过N的不调用AI（0=不限制）
# 比如限制AI处理前3个，快速验证结果，节省token

# 只对前N个三级模块调用AI（默认0）
l3_modules_ai__limit: 0

# 只对前N个功能过程调用FPA AI（默认0）
gen_fpa_ai_limit: 0

# 只对前N个功能过程调用COSMIC AI（默认0）
gen_cosmic_ai_limit: 0

# 只对前N个功能过程调用SPEC AI（默认0）
gen_spec_ai_limit: 0

# 是否对文档元数据的“#AI生成#”标记调用AI填充
# false=保留 #AI生成# 原文，不调用AI，（默认true）
# 在debug时，可以设置为false，快速验证，节省token
enable_ai_fill_meta: true

# FPA核减后的工作量，是否直接用FPA工作量的值
# false=由用户输入确认，默认false
# true=直接用FPA工作量的值
# 在debug时，可以设置为true，减小交互
fpa_reduced_use_workload: false

# 是否尝试使用 Excel COM / LibreOffice 复算 FPA Excel 公式并校验总工作量
# false=默认跳过；true=可用则复算，不可用或不一致只记录 warning，不阻断生成
fpa_excel_recalc_check: false

# debug设置 结束


# 保持不变 开始

# 以下基本不用改动

# 功能清单-录入模板.xlsx的Sheet名称映射
sheets:
  work_order_meta: "1、工单需求-元数据录入"
  func_list: "2、功能清单-内容录入"
  fpa_meta: "3、FPA工作量评估-元数据录入"
  spec_meta: "4、项目需求说明书-元数据录入"
  cosmic_meta: "5、项目功能点拆分表-元数据录入"
  list_meta: "6、项目需求清单-元数据录入"
  stats_meta: "7、测试-元数据自动统计"

# FPA工作量评估-输出模板.xlsx
# “计算依据归类判定原则”所在的Sheet名称
fpa_appendix_sheet: "附录1-FPA评估方法说明"

# “FPA功能点估算”Sheet名称
fpa_sheet: "FPA功能点估算"

# 输出文档使用的模板路径（优先级：CLI参数/Web UI指定 > 此配置）
# 相对路径基于项目根目录，也支持绝对路径
out_templates:
  fpa_out_template: data/out_templates/FPA工作量评估-输出模板.xlsx
  spec_out_template: data/out_templates/项目需求说明书-输出模板.docx
  cosmic_out_template: data/out_templates/项目功能点拆分表-输出模板.xlsx
  list_out_template: data/out_templates/项目需求清单-输出模板.xlsx

# 保持不变 结束
