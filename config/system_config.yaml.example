# COSMIC 功能点拆分工具 — 通用配置示例

# AI 每次调用的最大输出 token 数（支持 K/M 单位，如 384K）
max_tokens: 6000

# 是否重新生成各阶段文件（false=有文件则跳过，true=总是重新生成）
# 只对前 N 个 L3 模块调用 AI，超过的不走 AI（0=不限制）
# 限制 AI 批处理数量，超过的不走 AI（0=不限制，对各流程各自生效）
# 只对前 N 个 L3 模块调用 AI（保留兼容，优先使用 max_ai_items）
max_ai_l3_modules: 0

# FPA 核减后的工作量是否直接用 FPA 工作量的值（false=由用户输入确认）
fpa_reduced_use_workload: false

# 完成后是否播放提示音（默认 false）
notify_sound: false

# COSMIC 拆分表是否标记数据异常警告（默认 true）
cosmic_warn_marker: true

# 项目需求说明书文件名是否添加「【提醒】请手动更新整个目录」前缀（默认 true）
spec_remind_update_toc: true

# 是否用 Word COM 自动更新项目需求说明书的目录（需安装 Microsoft Word，默认 false）
spec_auto_update_toc: false

# FPA AI 只处理前 N 个功能过程（0=不限制）
gen_fpa_ai_limit: 0

# COSMIC AI 只处理前 N 个功能过程（0=不限制）
gen_cosmic_ai_limit: 0

# spec AI 只完善前 N 个功能过程描述（0=不限制）
gen_spec_ai_limit: 0

# 是否对文档元数据的 #AI生成# 标记走 AI 填充（false=保留原文 #AI生成# 标记）
enable_ai_fill_meta: true

# 功能清单-录入模板.xlsx 的 Sheet 名称
sheets:
  meta: "1、工单需求-元数据录入"
  func_content: "2、功能清单-内容录入"
  fpa_meta: "3、FPA工作量评估-元数据录入"
  spec_meta: "4、项目需求说明书-元数据录入"
  cosmic_meta: "6、项目功能点拆分表-元数据录入"
  require_meta: "7、项目需求清单-元数据录入"
  template_config: "8、各文档-模板路径录入"

# 输出文档模板路径（优先级：CLI参数 > 此配置 > data/templates/ 默认目录）
# 相对路径基于项目根目录，也支持绝对路径
out_templates:
  FPA工作量评估-模板: data/out_templates/FPA工作量评估-输出模板.xlsx
  项目需求说明书-模板: data/out_templates/项目需求说明书-输出模板.docx
  项目功能点拆分表-模板: data/out_templates/项目功能点拆分表-输出模板.xlsx
  项目需求清单-模板: data/out_templates/项目需求清单-输出模板.xlsx
