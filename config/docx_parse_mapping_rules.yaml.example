# =============================================================================
# docx 层级结构映射模板 — 实例与说明
# =============================================================================
# 此文件记录了解析 docx 时识别的 样式/编号 → 层级 映射规则。
# 规则由以下三种策略构成，每层级（L1/L2/L3/proc）各对应一条规则：
#
#   标题样式       → 按 Word 标题样式 ID 匹配
#   多级列表格式   → 按 (numId, ilvl) 精确匹配
#   编号格式       → 按 ilvl + numFmt 匹配（有编号的段落）
#
# 章节检测：无 ###标记 时，按此处配置的文本参数定位第4章
# =============================================================================

# 章节检测（无标记时用于定位章节，可多组，用 --chapter-detection 指定）
章节检测:
  default:
    section_begin_number: '4'                   # 章节开始编号
    section_begin_keyword: '功能需求'             # 章节开始标题关键字
    section_end_number: '5'                     # 章节结束编号（默认开始编号+1）
    section_end_keyword: '附加值调整因子说明'     # 章节结束标题关键字（可选）
  # 其他分组示例:
  # chapter3:
  #   section_number: '3'
  #   section_keyword: '业务需求'
# 自动生成的映射文件在 ~/.cosmic-tool/docx_parse_mapping_rules.yaml
# 每解析一个 docx 追加一条新的 mapping，以 mapping_时间戳 命名。
# 用户可在此配置文件中预定义命名的映射方案，供扩展使用。
# =============================================================================

层级映射:
  # -----------------------------------------------------------------------
  # mapping1：标题样式（对应 2.docx）
  # -----------------------------------------------------------------------
  # 文档使用 Heading 1~4 标题样式 + 正文（缩进）
  # 标记：###一级模块:标题样式### 在 Heading 2 段落上
  #       ###二级模块:标题样式### 在 Heading 3 段落上
  #       ###三级模块:标题样式### 在 Heading 4 段落上
  #       ###功能过程:编号格式### 在 正文（缩进）且有 ilvl 的段落上
  mapping1:
    L1: 标题样式 → style=5        # 匹配所有 Heading 2 段落
    L2: 标题样式 → style=7        # 匹配所有 Heading 3 段落
    L3: 标题样式 → style=8        # 匹配所有 Heading 4 段落
    proc: 编号格式 → ilvl=0       # 匹配所有 ilvl=0 的段落（含正文缩进）

  # -----------------------------------------------------------------------
  # mapping2：多级列表格式（对应 1.docx）
  # -----------------------------------------------------------------------
  # 文档全部使用 Normal 样式，无标题样式，层级通过多级列表（numId, ilvl）
  # 标记：###一级模块:多级列表格式### 在 (numId=6, ilvl=1) 段落上
  #       ###二级模块:多级列表格式### 在 (numId=7, ilvl=2) 段落上
  #       ###三级模块:多级列表格式### 在 (numId=7, ilvl=3) 段落上
  #       ###功能过程:多级列表格式### 在 (numId=7, ilvl=4) 段落上
  mapping2:
    L1: 多级列表格式 → numId=6, ilvl=1   # 匹配所有 (numId=6, ilvl=1) 段落
    L2: 多级列表格式 → numId=7, ilvl=2   # 匹配所有 (numId=7, ilvl=2) 段落
    L3: 多级列表格式 → numId=7, ilvl=3   # 匹配所有 (numId=7, ilvl=3) 段落
    proc: 多级列表格式 → numId=7, ilvl=4  # 匹配所有 (numId=7, ilvl=4) 段落

# =============================================================================
# 策略说明
# =============================================================================
# 标题样式     → 提取标记段落的 style_id，匹配文档中所有同 style_id 的段落
#                 适用场景：文档使用 Word 标题样式（Heading 1~6）
#                 style_id 在不同文档中可能不同，取决于 word_template.docx
#
# 多级列表格式 → 提取标记段落的 (numId, ilvl)，匹配所有同 (numId, ilvl) 的段落
#                 适用场景：文档使用多级列表/自动编号区分层级
#                 numId 是编号定义实例 ID，ilvl 是列表层级（0=顶层）
#
# 编号格式     → 提取标记段落的 ilvl，匹配所有同 ilvl 的段落（不论 numId）
#                 适用场景：各级别使用不同编号序列（numId 不同但 ilvl 相同）
#                 常用于配合标题样式识别功能过程
